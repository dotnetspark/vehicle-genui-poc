# vehicle-genui-poc environment variables.
# Copy this file to `.env` (already gitignored) and adjust values as needed.

# Postgres credentials — used by docker compose and by the ETL connection string.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=vehicles

# Connection string used by src/etl/etl.py (and later by mcp-postgres for the demos).
# Must match the credentials above.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vehicles

# Path to the DVLA VEH0120 CSV (gitignored). Override if your CSV has a different filename.
VEH0120_CSV=data/df_VEH0120_GB.csv
